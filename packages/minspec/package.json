{
  "name": "@aiclarity/minspec",
  "displayName": "MinSpec",
  "description": "Just enough spec. Never too much.",
  "version": "0.0.1",
  "private": true,
  "publisher": "aiclarity",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "keywords": ["sdd", "specification", "spec", "productivity", "ai"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "minspec.init",
        "title": "MinSpec: Initialize SDD Structure"
      },
      {
        "command": "minspec.classify",
        "title": "MinSpec: Classify Task Complexity"
      },
      {
        "command": "minspec.status",
        "title": "MinSpec: Show SDD Status"
      },
      {
        "command": "minspec.refreshTree",
        "title": "MinSpec: Refresh Spec Tree",
        "icon": "$(refresh)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "minspecStatus",
          "name": "MinSpec"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "minspec.refreshTree",
          "when": "view == minspecStatus",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "minspec.classify",
          "when": "viewItem == specNode",
          "group": "1_tier"
        }
      ]
    },
    "configuration": {
      "title": "MinSpec",
      "properties": {
        "minspec.specsDir": {
          "type": "string",
          "default": "specs",
          "description": "Directory for spec files (relative to workspace root)"
        },
        "minspec.decisionsDir": {
          "type": "string",
          "default": "docs/decisions",
          "description": "Directory for architecture decision records (relative to workspace root)"
        },
        "minspec.thresholds.t1Max": {
          "type": "number",
          "default": 3,
          "description": "Maximum complexity score for T1 (trivial) classification"
        },
        "minspec.thresholds.t2Max": {
          "type": "number",
          "default": 7,
          "description": "Maximum complexity score for T2 (small) classification"
        },
        "minspec.thresholds.t3Max": {
          "type": "number",
          "default": 14,
          "description": "Maximum complexity score for T3 (medium) classification"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run build -- --watch",
    "package": "vsce package --no-dependencies",
    "test": "vitest run"
  },
  "dependencies": {
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0"
  }
}
