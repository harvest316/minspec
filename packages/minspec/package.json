{
  "name": "minspec",
  "displayName": "MinSpec",
  "description": "Complexity-adaptive specification-driven development. Classifies changes into tiers and applies proportional ceremony — a one-line fix needs one sentence of spec, an architecture rewrite gets the full treatment.",
  "version": "0.1.19",
  "private": true,
  "publisher": "aiclarity",
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/harvest316/minspec"
  },
  "bugs": {
    "url": "https://github.com/harvest316/minspec/issues"
  },
  "preview": false,
  "homepage": "https://minspec.dev",
  "qna": "marketplace",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Testing"
  ],
  "keywords": [
    "sdd",
    "specification",
    "spec",
    "productivity",
    "ai",
    "spec-driven",
    "complexity",
    "classifier"
  ],
  "badges": [
    {
      "url": "https://github.com/harvest316/minspec/actions/workflows/ci.yml/badge.svg",
      "href": "https://github.com/harvest316/minspec/actions/workflows/ci.yml",
      "description": "CI Status"
    },
    {
      "url": "https://img.shields.io/badge/License-MIT-yellow.svg",
      "href": "https://opensource.org/licenses/MIT",
      "description": "MIT License"
    },
    {
      "url": "https://img.shields.io/badge/VS%20Code-1.90+-blue.svg",
      "href": "https://code.visualstudio.com/",
      "description": "VS Code 1.90+"
    },
    {
      "url": "https://img.shields.io/badge/TypeScript-5.0+-3178C6.svg",
      "href": "https://www.typescriptlang.org/",
      "description": "TypeScript 5.0+"
    }
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "minspec.init",
        "title": "MinSpec: Initialize SDD Structure"
      },
      {
        "command": "minspec.initRefresh",
        "title": "MinSpec: Refresh Harness Files"
      },
      {
        "command": "minspec.constitutionShowPrompt",
        "title": "MinSpec: Show Constitution Generation Prompt"
      },
      {
        "command": "minspec.constitutionPropose",
        "title": "MinSpec: Propose Constitution (draft)"
      },
      {
        "command": "minspec.constitutionCompact",
        "title": "MinSpec: Compact Constitution"
      },
      {
        "command": "minspec.classify",
        "title": "MinSpec: Classify Task Complexity"
      },
      {
        "command": "minspec.status",
        "title": "MinSpec: Show SDD Status"
      },
      {
        "command": "minspec.refreshTree",
        "title": "MinSpec: Refresh Spec Tree",
        "icon": "$(refresh)"
      },
      {
        "command": "minspec.declareScope",
        "title": "MinSpec: Declare Session Scope"
      },
      {
        "command": "minspec.park",
        "title": "MinSpec: Park Topic"
      },
      {
        "command": "minspec.parkForce",
        "title": "MinSpec: Park Topic (force)"
      },
      {
        "command": "minspec.injectContext",
        "title": "MinSpec: Inject Active Spec Context"
      },
      {
        "command": "minspec.removeContext",
        "title": "MinSpec: Remove Active Spec Context"
      },
      {
        "command": "minspec.showSpecPanel",
        "title": "MinSpec: Show Active Spec Panel"
      },
      {
        "command": "minspec.generateExample",
        "title": "MinSpec: Generate Example Spec"
      },
      {
        "command": "minspec.migrateLayout",
        "title": "MinSpec: Migrate Spec Layout (Flat ↔ Spec Kit)"
      },
      {
        "command": "minspec.createAdr",
        "title": "MinSpec: Create Architecture Decision Record",
        "shortTitle": "New ADR",
        "icon": "$(add)"
      },
      {
        "command": "minspec.regenerateDrIndex",
        "title": "MinSpec: Regenerate Decision Register INDEX",
        "icon": "$(list-tree)"
      },
      {
        "command": "minspec.createEpic",
        "title": "MinSpec: Create Epic",
        "shortTitle": "New Epic",
        "icon": "$(milestone)"
      },
      {
        "command": "minspec.regenerateEpicIndex",
        "title": "MinSpec: Regenerate Epic INDEX",
        "icon": "$(list-tree)"
      },
      {
        "command": "minspec.backfillEpics",
        "title": "MinSpec: Backfill Epics (AI-assisted)",
        "icon": "$(sparkle)"
      },
      {
        "command": "minspec.acceptEpic",
        "title": "MinSpec: Accept Epic",
        "shortTitle": "Accept",
        "icon": "$(check)"
      },
      {
        "command": "minspec.specExplorer.toggleEpicGrouping",
        "title": "MinSpec: Toggle Group by Epic (Specs)",
        "icon": "$(milestone)"
      },
      {
        "command": "minspec.adrExplorer.toggleEpicGrouping",
        "title": "MinSpec: Toggle Group by Epic (Decisions)",
        "icon": "$(milestone)"
      },
      {
        "command": "minspec.backlog.toggleEpicGrouping",
        "title": "MinSpec: Toggle Group by Epic (Backlog)",
        "icon": "$(milestone)"
      },
      {
        "command": "minspec.acceptAdr",
        "title": "MinSpec: Accept Decision",
        "shortTitle": "Accept",
        "icon": "$(check)"
      },
      {
        "command": "minspec.setAdrStatus",
        "title": "MinSpec: Set Decision Status…",
        "icon": "$(circle-outline)"
      },
      {
        "command": "minspec.scoreWsjf",
        "title": "MinSpec: Score Issue (WSJF)"
      },
      {
        "command": "minspec.triageIssue",
        "title": "MinSpec: Quick Triage Inbox Issue"
      },
      {
        "command": "minspec.refreshBacklog",
        "title": "MinSpec: Refresh Backlog",
        "icon": "$(refresh)"
      },
      {
        "command": "minspec.goToSpec",
        "title": "MinSpec: Go to Spec Requirement"
      },
      {
        "command": "minspec.goToCode",
        "title": "MinSpec: Go to Code Location"
      },
      {
        "command": "minspec.linkToSpec",
        "title": "MinSpec: Link Code to Spec Requirement"
      },
      {
        "command": "minspec.exportTraceability",
        "title": "MinSpec: Export Traceability for ScroogeLLM"
      },
      {
        "command": "minspec.approveSpec",
        "title": "MinSpec: Approve Spec for Implementation",
        "shortTitle": "Approve",
        "icon": "$(check)"
      },
      {
        "command": "minspec.revokeApproval",
        "title": "MinSpec: Revoke Spec Approval",
        "icon": "$(unverified)"
      },
      {
        "command": "minspec.validateSpec",
        "title": "MinSpec: Check Spec Completeness"
      },
      {
        "command": "minspec.approveActive",
        "title": "MinSpec: Approve/Accept Active",
        "shortTitle": "Approve/Accept",
        "icon": "$(check-all)"
      }
    ],
    "keybindings": [
      {
        "command": "minspec.approveActive",
        "key": "alt+a",
        "when": "editorTextFocus || focusedView == minspecStatus || focusedView == minspecAdrs || focusedView == minspecBacklog"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "minspecStatus",
          "name": "MinSpec: Specs"
        },
        {
          "id": "minspecAdrs",
          "name": "MinSpec: Decisions"
        },
        {
          "id": "minspecBacklog",
          "name": "MinSpec: Backlog"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "minspec.acceptEpic",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "minspec.refreshTree",
          "when": "view == minspecStatus",
          "group": "navigation"
        },
        {
          "command": "minspec.specExplorer.toggleEpicGrouping",
          "when": "view == minspecStatus",
          "group": "navigation"
        },
        {
          "command": "minspec.refreshTree",
          "when": "view == minspecAdrs",
          "group": "navigation"
        },
        {
          "command": "minspec.createAdr",
          "when": "view == minspecAdrs",
          "group": "navigation"
        },
        {
          "command": "minspec.regenerateDrIndex",
          "when": "view == minspecAdrs",
          "group": "navigation"
        },
        {
          "command": "minspec.adrExplorer.toggleEpicGrouping",
          "when": "view == minspecAdrs",
          "group": "navigation"
        },
        {
          "command": "minspec.createEpic",
          "when": "view == minspecAdrs",
          "group": "navigation"
        },
        {
          "command": "minspec.backfillEpics",
          "when": "view == minspecAdrs",
          "group": "navigation"
        },
        {
          "command": "minspec.refreshBacklog",
          "when": "view == minspecBacklog",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "minspec.acceptEpic",
          "when": "viewItem == epicGroup.proposed",
          "group": "inline"
        },
        {
          "command": "minspec.acceptEpic",
          "when": "viewItem == epicGroup.proposed",
          "group": "1_epic"
        },
        {
          "command": "minspec.classify",
          "when": "viewItem == specNode",
          "group": "1_tier"
        },
        {
          "command": "minspec.approveSpec",
          "when": "view == minspecStatus && viewItem == specNode",
          "group": "inline"
        },
        {
          "command": "minspec.approveSpec",
          "when": "view == minspecStatus && viewItem == specNode",
          "group": "2_approval@1"
        },
        {
          "command": "minspec.revokeApproval",
          "when": "view == minspecStatus && viewItem == specNode.approved",
          "group": "2_approval@2"
        },
        {
          "command": "minspec.acceptAdr",
          "when": "view == minspecAdrs && viewItem == adrNode.proposed",
          "group": "inline"
        },
        {
          "command": "minspec.acceptAdr",
          "when": "view == minspecAdrs && viewItem == adrNode.proposed",
          "group": "1_status@1"
        },
        {
          "command": "minspec.setAdrStatus",
          "when": "view == minspecAdrs && viewItem =~ /^adrNode/",
          "group": "1_status@2"
        },
        {
          "command": "minspec.scoreWsjf",
          "when": "viewItem == backlogIssueNode",
          "group": "1_scoring"
        },
        {
          "command": "minspec.triageIssue",
          "when": "viewItem == backlogIssueNode",
          "group": "2_triage"
        }
      ]
    },
    "configuration": {
      "title": "MinSpec",
      "properties": {
        "minspec.specsDir": {
          "type": "string",
          "default": "specs",
          "description": "Directory for spec files (relative to workspace root)"
        },
        "minspec.decisionsDir": {
          "type": "string",
          "default": "docs/decisions",
          "description": "Directory for architecture decision records (relative to workspace root)"
        },
        "minspec.specsLayout": {
          "type": "string",
          "enum": [
            "flat",
            "spec-kit"
          ],
          "default": "flat",
          "description": "How spec files are stored. 'flat': one file per spec (specs/SPEC-NNN-slug.md). 'spec-kit': one directory per spec with separate spec.md/plan.md/tasks.md — strict GitHub Spec Kit compatibility."
        },
        "minspec.codelens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable CodeLens annotations showing spec requirement mappings"
        },
        "minspec.conformance.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Auto-export traceability when ScroogeLLM is detected (for conformance checking)"
        },
        "minspec.scroogellmNudge.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show ScroogeLLM installation suggestion when not installed"
        },
        "minspec.autoBootstrap.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Auto-detect missing initialization, harness drift, and unclassified changes — and offer to run setup/refresh/classify. Per-prompt 'Don't ask again' choices are persisted in .minspec/preferences.json."
        },
        "minspec.autoClassifyOnCommit": {
          "type": "boolean",
          "default": false,
          "description": "Automatically run 'MinSpec: Classify Task Complexity' after each git commit (watches .git/HEAD and .git/refs/heads/*). Off by default."
        },
        "minspec.autoBackfillUseAi": {
          "type": "boolean",
          "default": false,
          "description": "Always use the AI pass when backfilling epics (skips the per-run 'AI-enhanced?' prompt). Set globally by choosing 'Always' on that prompt — a personal preference that follows you across projects. Runs 'claude -p' locally; the extension makes no network calls. Off by default."
        }
      }
    },
    "walkthroughs": [
      {
        "id": "minspec.gettingStarted",
        "title": "Get Started with MinSpec",
        "description": "Learn Specification-Driven Development in 5 steps.",
        "steps": [
          {
            "id": "minspec.walkthrough.welcome",
            "title": "Welcome to MinSpec",
            "description": "MinSpec brings Specification-Driven Development (SDD) to VS Code. Classify tasks by complexity, write just enough spec, and ship with confidence.\n\n**Ceremony proportional to complexity** — a one-line fix needs one sentence of spec. A new subsystem gets the full treatment.",
            "media": {
              "markdown": "media/walkthrough/welcome.md"
            }
          },
          {
            "id": "minspec.walkthrough.init",
            "title": "Initialize Your Project",
            "description": "Set up the `.minspec/` directory, specs folder, and default configuration.\n\n[Initialize SDD Structure](command:minspec.init)",
            "media": {
              "markdown": "media/walkthrough/init-project.md"
            },
            "completionEvents": [
              "onCommand:minspec.init"
            ]
          },
          {
            "id": "minspec.walkthrough.classify",
            "title": "Classify Your First Task",
            "description": "Every task gets a complexity tier (T1-T4) that determines how much spec to write. The classifier suggests — you decide.\n\n[Classify Task](command:minspec.classify)",
            "media": {
              "markdown": "media/walkthrough/classify-task.md"
            },
            "completionEvents": [
              "onCommand:minspec.classify"
            ]
          },
          {
            "id": "minspec.walkthrough.sidebar",
            "title": "Explore the Sidebar",
            "description": "The MinSpec panel in the Explorer sidebar shows all your specs, their tiers, phases, and task progress. The status bar tracks your active spec at a glance.",
            "media": {
              "markdown": "media/walkthrough/explore-sidebar.md"
            }
          },
          {
            "id": "minspec.walkthrough.aiIntegration",
            "title": "Integrate with AI Tools",
            "description": "Inject your active spec context into CLAUDE.md, .cursorrules, or other AI tool configs. Keeps AI suggestions aligned with your specification.\n\n[Inject Context](command:minspec.injectContext)",
            "media": {
              "markdown": "media/walkthrough/ai-integration.md"
            },
            "completionEvents": [
              "onCommand:minspec.injectContext"
            ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "build:shared": "tsc -p ../shared/tsconfig.json",
    "prebuild": "npm run build:shared",
    "build": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify",
    "prebuild:prod": "npm run build:shared",
    "build:prod": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify --sourcemap=external",
    "watch": "npm run build -- --watch --sourcemap",
    "supply-chain:check": "../../scripts/check-supply-chain.sh",
    "prepackage": "npm run supply-chain:check",
    "package": "npm run build:prod && vsce package --no-dependencies",
    "prepublish": "npm run supply-chain:check",
    "test": "vitest run",
    "bench": "vitest bench",
    "pretest:e2e": "npm run build && tsc -p tsconfig.test.json",
    "test:e2e": "vscode-test"
  },
  "dependencies": {
    "@aiclarity/shared": "*",
    "handlebars": "^4.7.9",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@vscode/test-cli": "0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "0.28.0",
    "mocha": "^11.3.0",
    "vitest": "4.1.7"
  }
}
